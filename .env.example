# Copy this file to .env and fill in the values

# JWT Secret for signing tokens (generate with: node -e "console.log('JWT_SECRET=' + require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-secret-here

# MongoDB connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/rast7?appName=Latihan

# Gmail SMTP for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-16-char

# Frontend URL (for reset link in email)
# Ganti ke domain Vercel kalau production, contoh: https://rast7.vercel.app
FRONTEND_URL=http://localhost:5173