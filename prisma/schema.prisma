generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model users {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  avatar    Bytes?
  birthday  String?
  createdAt DateTime @db.Date
  email     String @unique
  gender    String?
  joinDate  String?
  password  String
  username  String @unique

  // Tambahan untuk fitur platform Rast7
  level     Int      @default(1)
  points    Int      @default(0) // Untuk menampung saldo poin
  isAdmin   Boolean  @default(false) // Admin role flag

  // Relasi: Satu user bisa memiliki banyak riwayat transaksi
  transactions transactions[]

  // Relasi ke contact_messages
  contact_messages contact_messages[]
}


// ==========================================
// 2. GAMES & ITEMS
// Untuk menggantikan listDiamond statis di frontend
// ==========================================
model games {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // "Mobile Legends: Bang Bang"
  slug        String   @unique // "mlbb", "roblox"
  logo        Bytes?   // Game logo image binary
  itemIcon    Bytes?   // Icon shown on item cards (binary)

  bg                 Bytes?    // Background image binary
  bgPosition         String?   // "50% calc(50% - 300px)"
  badge              String?   // "Hot", "New", "Promo", or null
  categoryId         String?   @db.ObjectId
  category           categories? @relation(fields: [categoryId], references: [id])
  hasZone            Boolean   @default(true)
  userIdLabel        String    @default("USER ID")
  userIdPlaceholder  String    @default("Masukkan User ID")
  zoneIdLabel        String    @default("ZONE ID")
  zoneIdPlaceholder  String    @default("Zone ID")
  zoneIdHint         String    @default("4 DIGIT")
  zoneIdMaxLength    Int       @default(4)

  // Embedded Document: Katalog harga diamond/robux/VP
  items       TopUpItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tipe data bersarang (Embedded Document) khusus MongoDB
type TopUpItem {
  qty             Int     // 89
  itemName        String  // "Diamonds", "Robux", "Valorant Points"
  originalPrice   Float   // 16000
  discountPercent Float   @default(0) // 10
  finalPrice      Float   // 14400
}

// ==========================================
// 3. CATEGORIES
// For game categorization (Mobile, PC, RPG, etc.)
// ==========================================
model categories {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique // "Mobile", "PC", "RPG"
  slug      String   @unique // "mobile", "pc", "rpg"
  createdAt DateTime @default(now())

  games     games[]
}

// ==========================================
// 4. PAYMENT METHODS
// Untuk menggantikan listPayment statis di frontend
// ==========================================
model payment_methods {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique // "Gopay", "Dana", "QRIS"
  logoUrl     String   // "/asset/logo_payment/gopay.png"
  taxPercent  Float    @default(11) // Pajak standar

  createdAt   DateTime @default(now())
}

// ==========================================
// 4. TRANSACTIONS
// Menyimpan riwayat invoice (Struktur Snapshot)
// ==========================================
model transactions {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId       String   @unique // "RAST7-XXXXXXXXX"
  
  // Relasi ke tabel users
  userId          String   @db.ObjectId
  user            users    @relation(fields: [userId], references: [id])

  // Data Target Top-Up (Sesuai input dari game)
  accountId       String   // "USER ID" atau "RIOT ID"
  zoneId          String?  // "ZONE ID" (Opsional, karena Valorant tidak butuh)

  // Snapshot Pembelian (Disalin agar tidak berubah jika harga game naik)
  gameName        String   // "Mobile Legends"
  itemName        String   // "Diamonds"
  itemQty         Int      // 89
  paymentMethod   String   // "Gopay"

  // Rincian Tagihan
  basePrice       Float
  taxAmount       Float
  discountPoints  Int      @default(0) // Poin Rast7 yang digunakan
  totalPaid       Float

  status          String   @default("SUCCESS") // PENDING, SUCCESS, FAILED
  waktu           String?  // Format tanggal custom frontend: "29 Apr 2026, 21:00"

  createdAt       DateTime @default(now())
}

// ==========================================
// 5. VOUCHERS
// Untuk menggantikan hardcode "SUKSES77" di Voucher.jsx
// ==========================================
model vouchers {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  rewardValue Int       // Disesuaikan dengan data JSON (sebelumnya rewardPoint)
  quota       Int       @default(100)
  usedCount   Int       @default(0)   // INI YANG SEBELUMNYA HILANG
  rewardType  String?   // Opsional, menyesuaikan JSON
  isActive    Boolean   @default(true)
  validUntil  DateTime? // Opsional, menyesuaikan JSON

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// 6. VOUCHER REDEMPTIONS
// Tracks per-user voucher redemption (one-time use per user)
// ==========================================
model voucher_redemptions {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  voucherId String   @db.ObjectId
  code      String   // Denormalized for easy reference
  createdAt DateTime @default(now())

  @@index([userId, voucherId])
}

// ==========================================
// 7. CAROUSEL SLIDES
// For dynamic hero carousel content management
// ==========================================
model carousel_slides {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  image     Bytes?   // Slide background image
  title     String   // "Top Up Game Terpercaya"
  subtitle  String   // "Murah, Cepat, dan Aman..."
  cta       String   // "Lihat Game"
  link      String   // "#all-games"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 6. POINT CONFIGS
// Tier configuration for dynamic point rewards
// ==========================================
model point_configs {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  tierName    String  @unique
  minSpent    Float
  rewardRate  Float
  levelNumber Int     @unique
}

// ==========================================
// 8. PROMOS
// For dynamic campaign list on Promo Page
// ==========================================
model promos {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  category     String   // e.g. "Weekly Diamond Pass"
  gameName     String   // e.g. "Mobile Legends"
  periodText   String   // e.g. "1 Oktober–31 Desember 2025"
  timeText     String?  // e.g. "(15.00-18.00)"
  cashbackText String   // e.g. "Cashback 100% (maks. Rp27.195)"
  notes        String?  // e.g. "Promo hanya berlaku untuk pengguna RAST Plus"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ==========================================
// 9. PROMO BANNERS / CONFIGS
// For page-level header and config on Promo Page
// ==========================================
model promo_banners {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String   // "Promo Games: Cashback hingga..."
  periodText   String   // "Periode Promo 1-30 Okt 2025"
  regionText   String   @default("Seluruh Indonesia")
  categoryText String   @default("Games")
  subheading   String   // "Promo Mobile Legends di RAST Games..."
  image        Bytes?   // Page banner image binary
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ==========================================
// 10. CONTACT MESSAGES
// For user feedback/complaints on Contact Page
// ==========================================
model contact_messages {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      users    @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime @default(now())
}